# ============================================================
# PART2/01_Adapter/Makefile — 适配器模式
#
# 本章节演示：让不兼容的接口可以一起工作
# 适配器在嵌入式场景常用于：
#   旧驱动适配新框架、第三方库接口封装、固件升级兼容旧 API
#
# 用法：
#   make        — 编译（输出到 ../bin/adapter）
#   make clean  — 清理
#   make help   — 显示帮助
# ============================================================

# ------------------------------------------------------------
# 一、编译器与编译选项
# ------------------------------------------------------------

# CC = C 编译器（gcc）
CC      = gcc

# CFLAGS = 编译选项
#   -Wall  开启所有警告
#   -g     生成调试信息（gdb 调试用）
CFLAGS  = -Wall -g

# ------------------------------------------------------------
# 二、目录配置
# ------------------------------------------------------------

# SRCDIR = 源代码目录（Source Directory）
#   . 表示当前目录（Makefile 所在目录）
SRCDIR  = .

# OBJDIR = 目标文件目录（Object Directory）
#   ../obj/01_Adapter 表示上层目录下的 obj/01_Adapter
#   这样可以把 .o 文件和源代码分开存放
OBJDIR  = ../obj/01_Adapter

# BINDIR = 可执行文件目录（Binary Directory）
BINDIR  = ../bin

# ------------------------------------------------------------
# 三、目标配置
# ------------------------------------------------------------

# EXEC = 最终可执行文件的完整路径
EXEC    = $(BINDIR)/adapter

# SRC = 源文件路径
SRC     = $(SRCDIR)/code.c

# OBJ = 目标文件路径（.c → .o 存放在 OBJDIR）
OBJ     = $(OBJDIR)/code.o

# ------------------------------------------------------------
# 四、默认目标
# ------------------------------------------------------------

# all: 的默认入口，执行 dir（创建目录）和 build（编译链接）
all: dir build

# dir: 确保输出目录存在
#   @mkdir -p 表示不打印命令本身（@ 前缀），
#   -p 自动创建父目录（如果不存在）
dir:
	@mkdir -p $(OBJDIR)
	@mkdir -p $(BINDIR)

# build: 依赖目标文件 → 可执行文件
build: $(OBJ) $(EXEC)

# ------------------------------------------------------------
# 五、编译和链接规则
# ------------------------------------------------------------

# 链接规则：把所有 .o 文件链接成可执行文件
# $@ = 目标（即可执行文件路径）
# $< = 第一个依赖（即目标文件）
$(EXEC): $(OBJ)
	$(CC) $(CFLAGS) -o $@ $(OBJ)

# 编译规则：.c → .o
# 模式规则：$(OBJDIR)/%.o 表示匹配所有 .o 文件
#            对应的依赖是 $(SRCDIR)/%.c
# $< = 正在处理的 .c 文件
# -o $@ = 输出为对应的 .o 文件
$(OBJDIR)/%.o: $(SRCDIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# ------------------------------------------------------------
# 六、清理
# ------------------------------------------------------------

# -rm -rf 强制递归删除（-f 忽略不存在的文件）
# -rmdir 2>/dev/null || true 尝试删除目录，忽略错误
clean:
	-rm -rf $(EXEC) $(OBJ)
	-rmdir $(OBJDIR) 2>/dev/null || true

# ------------------------------------------------------------
# 七、伪目标（不是文件名，只是标签）
# ------------------------------------------------------------

.PHONY: all dir build clean help

# help: 显示帮助信息
help:
	@echo "01_Adapter - 适配器模式"
	@echo ""
	@echo "用法:"
	@echo "  make          编译（输出到 ../bin/adapter）"
	@echo "  ./adapter     运行"
	@echo "  make clean    清理"
