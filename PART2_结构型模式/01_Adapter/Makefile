# 01_Adapter/Makefile - 适配器模式编译脚本
#
# 编译目标：adapter
# 编译命令：make
# 清理命令：make clean
#
# 用法：
#   $ make          # 编译
#   $ ./adapter     # 运行
#   $ make clean    # 清理

# ============================================================
# 目录配置
# ============================================================
# 代码目录（相对于 Makefile 位置）
SRCDIR = .
# 临时目标文件目录
OBJDIR = ../obj/01_Adapter
# 最终可执行文件目录
BINDIR = ../bin

# ============================================================
# 编译器配置
# ============================================================
CC      = gcc                     # C 编译器
CFLAGS  = -Wall -g               # 警告 + 调试符号
# 如果需要 C 语言扩展特性（如 block literals），可以启用：
# CFLAGS += -fms-extensions

# ============================================================
# 目标配置
# ============================================================
# 可执行文件名
EXEC    = $(BINDIR)/adapter
# 源文件
SRC     = $(SRCDIR)/code.c
# 目标文件（.o）
OBJ     = $(OBJDIR)/code.o

# ============================================================
# 默认目标
# ============================================================
all: dir build

# 创建目录
dir:
	@mkdir -p $(OBJDIR)
	@mkdir -p $(BINDIR)

# 链接
build: $(OBJ) $(EXEC)

# 链接规则：把所有目标文件链接成可执行文件
$(EXEC): $(OBJ)
	$(CC) $(CFLAGS) -o $@ $(OBJ)

# 编译规则：.c -> .o
$(OBJDIR)/%.o: $(SRCDIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# ============================================================
# 清理
# ============================================================
clean:
	-rm -rf $(EXEC) $(OBJ)
	-rmdir $(OBJDIR) 2>/dev/null || true

# ============================================================
# 伪目标：显示帮助
# ============================================================
.PHONY: help
help:
	@echo "01_Adapter - 适配器模式"
	@echo ""
	@echo "Usage:"
	@echo "  make          Compile"
	@echo "  ./adapter     Run"
	@echo "  make clean    Clean"

# ============================================================
# 依赖关系（如果 code.c 引用了其他 .h）
# ============================================================
# code.c 本身是独立文件，不依赖外部头文件
# 但如果添加了 base.h 等通用头文件，需要在这里声明：
# $(OBJ): $(SRCDIR)/base.h
