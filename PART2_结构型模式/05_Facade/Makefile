# 05_Facade/Makefile - 外观模式编译脚本
#
# 编译目标：facade
# 编译命令：make
# 清理命令：make clean

# ============================================================
# 目录配置
# ============================================================
SRCDIR  = .
OBJDIR  = ../obj/05_Facade
BINDIR  = ../bin

# ============================================================
# 编译器配置
# ============================================================
CC      = gcc
CFLAGS  = -Wall -g

# ============================================================
# 目标配置
# ============================================================
EXEC    = $(BINDIR)/facade
SRC     = $(SRCDIR)/code.c
OBJ     = $(OBJDIR)/code.o

# ============================================================
# 默认目标
# ============================================================
all: dir build

dir:
	@mkdir -p $(OBJDIR)
	@mkdir -p $(BINDIR)

build: $(OBJ) $(EXEC)

$(EXEC): $(OBJ)
	$(CC) $(CFLAGS) -o $@ $(OBJ)

$(OBJDIR)/%.o: $(SRCDIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	-rm -rf $(EXEC) $(OBJ)

.PHONY: help
help:
	@echo "05_Facade - 外观模式"
	@echo "Usage: make && ./facade"
