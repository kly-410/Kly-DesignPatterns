# ============================================================
# PART2/05_Facade/Makefile — 外观模式
#
# 本章节演示：为复杂子系统提供统一简化接口
# 外观模式在嵌入式场景常用于：
#   PCIe 设备初始化：配置BAR → 使能中断 → 初始化DMA → 设置电源管理
#   一键启动复杂外设（用户只需调用 init_all()）
#
# 用法：
#   make        — 编译（输出到 ../bin/facade）
#   make clean  — 清理
# ============================================================

# ------------------------------------------------------------
# 一、目录配置
# ------------------------------------------------------------

SRCDIR  = .                           # 源代码目录
OBJDIR  = ../obj/05_Facade           # 目标文件目录
BINDIR  = ../bin                      # 可执行文件目录

# ------------------------------------------------------------
# 二、编译器配置
# ------------------------------------------------------------

CC      = gcc
CFLAGS  = -Wall -g

# ------------------------------------------------------------
# 三、目标配置
# ------------------------------------------------------------

EXEC    = $(BINDIR)/facade            # 可执行文件
SRC     = $(SRCDIR)/code.c            # 源文件
OBJ     = $(OBJDIR)/code.o            # 目标文件

# ------------------------------------------------------------
# 四、默认目标
# ------------------------------------------------------------

all: dir build                        # 创建目录 → 编译链接

dir:
	@mkdir -p $(OBJDIR)
	@mkdir -p $(BINDIR)

build: $(OBJ) $(EXEC)

# ------------------------------------------------------------
# 五、编译和链接规则
# ------------------------------------------------------------

$(EXEC): $(OBJ)
	$(CC) $(CFLAGS) -o $@ $(OBJ)

$(OBJDIR)/%.o: $(SRCDIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# ------------------------------------------------------------
# 六、清理
# ------------------------------------------------------------

clean:
	-rm -rf $(EXEC) $(OBJ)

.PHONY: all dir build clean help

help:
	@echo "05_Facade - 外观模式"
	@echo "用法: make && ./facade"
