# 02_Bridge/Makefile - 桥接模式编译脚本
#
# 编译目标：bridge
# 编译命令：make
# 清理命令：make clean
#
# 用法：
#   $ make        # 编译
#   $ ./bridge    # 运行
#   $ make clean  # 清理

# ============================================================
# 目录配置
# ============================================================
SRCDIR  = .
OBJDIR  = ../obj/02_Bridge
BINDIR  = ../bin

# ============================================================
# 编译器配置
# ============================================================
CC      = gcc
CFLAGS  = -Wall -g

# ============================================================
# 目标配置
# ============================================================
EXEC    = $(BINDIR)/bridge
SRC     = $(SRCDIR)/code.c
OBJ     = $(OBJDIR)/code.o

# ============================================================
# 默认目标
# ============================================================
all: dir build

dir:
	@mkdir -p $(OBJDIR)
	@mkdir -p $(BINDIR)

build: $(OBJ) $(EXEC)

$(EXEC): $(OBJ)
	$(CC) $(CFLAGS) -o $@ $(OBJ)

$(OBJDIR)/%.o: $(SRCDIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# ============================================================
# 清理
# ============================================================
clean:
	-rm -rf $(EXEC) $(OBJ)

.PHONY: help
help:
	@echo "02_Bridge - 桥接模式"
	@echo "Usage: make && ./bridge"
