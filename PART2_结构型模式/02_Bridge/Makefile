# ============================================================
# PART2/02_Bridge/Makefile — 桥接模式
#
# 本章节演示：分离抽象与实现，使两者可以独立变化
# 桥接模式在嵌入式场景常用于：
#   设备类型（PCIe网卡、SATA SSD）× 传输协议（NVMe、AHCI）自由组合
#
# 用法：
#   make        — 编译（输出到 ../bin/bridge）
#   make clean  — 清理
# ============================================================

# ------------------------------------------------------------
# 一、目录配置
# ------------------------------------------------------------

SRCDIR  = .# 源代码目录（当前目录）
OBJDIR  = ../obj/02_Bridge# 目标文件目录
BINDIR  = ../bin# 可执行文件目录

# ------------------------------------------------------------
# 二、编译器配置
# ------------------------------------------------------------

CC      = gcc# C 编译器
CFLAGS  = -Wall -g                    # 警告 + 调试信息

# ------------------------------------------------------------
# 三、目标配置
# ------------------------------------------------------------

EXEC    = $(BINDIR)/bridge# 可执行文件路径
SRC     = $(SRCDIR)/code.c# 源文件
OBJ     = $(OBJDIR)/code.o# 目标文件

# ------------------------------------------------------------
# 四、默认目标
# ------------------------------------------------------------

all: dir build                        # 创建目录 → 编译链接

# 创建目录（mkdir -p 自动创建父目录，不报错）
dir:
	@mkdir -p $(OBJDIR)
	@mkdir -p $(BINDIR)

# build 依赖：先有 .o 文件，再链接成可执行文件
build: $(OBJ) $(EXEC)

# ------------------------------------------------------------
# 五、编译和链接规则
# ------------------------------------------------------------

# 链接：$@ = 目标文件，$< = 依赖中的第一个
$(EXEC): $(OBJ)
	$(CC) $(CFLAGS) -o $@ $(OBJ)

# 编译：模式规则，.c → .o
# $(OBJDIR)/%.o 匹配所有 .o 文件
# $(SRCDIR)/%.c 是对应的源文件
$(OBJDIR)/%.o: $(SRCDIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# ------------------------------------------------------------
# 六、清理
# ------------------------------------------------------------

clean:
	-rm -rf $(EXEC) $(OBJ)

.PHONY: all dir build clean help

help:
	@echo "02_Bridge - 桥接模式"
	@echo "用法: make && ./bridge"
