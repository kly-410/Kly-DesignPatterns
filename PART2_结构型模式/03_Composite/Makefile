# ============================================================
# PART2/03_Composite/Makefile — 组合模式
#
# 本章节演示：将对象组合成树形结构，统一对待单个对象和组合对象
# 组合模式在嵌入式场景常用于：
#   PCIe 设备树（RC → Switch → Endpoint）
#   文件系统（文件夹包含文件和子文件夹）
#   组织架构（部门包含员工和子部门）
#
# 用法：
#   make        — 编译（输出到 ../bin/composite）
#   make clean  — 清理
# ============================================================

# ------------------------------------------------------------
# 一、目录配置
# ------------------------------------------------------------

SRCDIR  = .                           # 源代码目录
OBJDIR  = ../obj/03_Composite        # 目标文件目录
BINDIR  = ../bin                      # 可执行文件目录

# ------------------------------------------------------------
# 二、编译器配置
# ------------------------------------------------------------

CC      = gcc
CFLAGS  = -Wall -g

# ------------------------------------------------------------
# 三、目标配置
# ------------------------------------------------------------

EXEC    = $(BINDIR)/composite         # 可执行文件
SRC     = $(SRCDIR)/code.c            # 源文件
OBJ     = $(OBJDIR)/code.o            # 目标文件

# ------------------------------------------------------------
# 四、默认目标
# ------------------------------------------------------------

all: dir build                        # 创建目录 → 编译链接

dir:
	@mkdir -p $(OBJDIR)
	@mkdir -p $(BINDIR)

build: $(OBJ) $(EXEC)

# ------------------------------------------------------------
# 五、编译和链接规则
# ------------------------------------------------------------

$(EXEC): $(OBJ)
	$(CC) $(CFLAGS) -o $@ $(OBJ)

$(OBJDIR)/%.o: $(SRCDIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# ------------------------------------------------------------
# 六、清理
# ------------------------------------------------------------

clean:
	-rm -rf $(EXEC) $(OBJ)

.PHONY: all dir build clean help

help:
	@echo "03_Composite - 组合模式"
	@echo "用法: make && ./composite"
