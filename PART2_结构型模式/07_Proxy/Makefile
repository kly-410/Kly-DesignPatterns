# ============================================================
# PART2/07_Proxy/Makefile — 代理模式
#
# 本章节演示：控制对对象的访问（延迟加载、权限控制、缓存等）
# 代理模式在嵌入式场景常用于：
#   远程设备访问（本地代理转发请求到远程）
#   大数据结构延迟加载（Proxy 持有引用，真正需要时才加载）
#   权限验证代理（访问敏感配置前检查权限）
#
# 用法：
#   make        — 编译（输出到 ../bin/proxy）
#   make clean  — 清理
# ============================================================

# ------------------------------------------------------------
# 一、目录配置
# ------------------------------------------------------------

SRCDIR  = .# 源代码目录
OBJDIR  = ../obj/07_Proxy# 目标文件目录
BINDIR  = ../bin# 可执行文件目录

# ------------------------------------------------------------
# 二、编译器配置
# ------------------------------------------------------------

CC      = gcc
CFLAGS  = -Wall -g

# ------------------------------------------------------------
# 三、目标配置
# ------------------------------------------------------------

EXEC    = $(BINDIR)/proxy# 可执行文件
SRC     = $(SRCDIR)/code.c# 源文件
OBJ     = $(OBJDIR)/code.o# 目标文件

# ------------------------------------------------------------
# 四、默认目标
# ------------------------------------------------------------

all: dir build                        # 创建目录 → 编译链接

dir:
	@mkdir -p $(OBJDIR)
	@mkdir -p $(BINDIR)

build: $(OBJ) $(EXEC)

# ------------------------------------------------------------
# 五、编译和链接规则
# ------------------------------------------------------------

$(EXEC): $(OBJ)
	$(CC) $(CFLAGS) -o $@ $(OBJ)

$(OBJDIR)/%.o: $(SRCDIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# ------------------------------------------------------------
# 六、清理
# ------------------------------------------------------------

clean:
	-rm -rf $(EXEC) $(OBJ)

.PHONY: all dir build clean help

help:
	@echo "07_Proxy - 代理模式"
	@echo "用法: make && ./proxy"
