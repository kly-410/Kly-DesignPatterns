# ============================================================
# PART2/06_Flyweight/Makefile — 享元模式
#
# 本章节演示：共享细粒度对象，大幅减少内存使用
# 享元模式在嵌入式场景常用于：
#   大量相似对象：日志格式（相同格式模板，不同消息内容）
#   固件中的字符串表、枚举描述、协议头模板
#
# 用法：
#   make        — 编译（输出到 ../bin/flyweight）
#   make clean  — 清理
# ============================================================

# ------------------------------------------------------------
# 一、目录配置
# ------------------------------------------------------------

SRCDIR  = .                           # 源代码目录
OBJDIR  = ../obj/06_Flyweight        # 目标文件目录
BINDIR  = ../bin                      # 可执行文件目录

# ------------------------------------------------------------
# 二、编译器配置
# ------------------------------------------------------------

CC      = gcc
CFLAGS  = -Wall -g

# ------------------------------------------------------------
# 三、目标配置
# ------------------------------------------------------------

EXEC    = $(BINDIR)/flyweight         # 可执行文件
SRC     = $(SRCDIR)/code.c            # 源文件
OBJ     = $(OBJDIR)/code.o            # 目标文件

# ------------------------------------------------------------
# 四、默认目标
# ------------------------------------------------------------

all: dir build                        # 创建目录 → 编译链接

dir:
	@mkdir -p $(OBJDIR)
	@mkdir -p $(BINDIR)

build: $(OBJ) $(EXEC)

# ------------------------------------------------------------
# 五、编译和链接规则
# ------------------------------------------------------------

$(EXEC): $(OBJ)
	$(CC) $(CFLAGS) -o $@ $(OBJ)

$(OBJDIR)/%.o: $(SRCDIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# ------------------------------------------------------------
# 六、清理
# ------------------------------------------------------------

clean:
	-rm -rf $(EXEC) $(OBJ)

.PHONY: all dir build clean help

help:
	@echo "06_Flyweight - 享元模式"
	@echo "用法: make && ./flyweight"
