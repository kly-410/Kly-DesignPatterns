# ============================================================
# PART2/04_Decorator/Makefile — 装饰器模式
#
# 本章节演示：动态给对象添加功能，比继承更灵活
# 装饰器模式在嵌入式场景常用于：
#   日志加时间戳 → 加 CRC → 加加密（层层叠加）
#   I/O 流加缓冲 → 加压缩 → 加加密
#
# 用法：
#   make        — 编译（输出到 ../bin/decorator）
#   make clean  — 清理
# ============================================================

# ------------------------------------------------------------
# 一、目录配置
# ------------------------------------------------------------

SRCDIR  = .# 源代码目录
OBJDIR  = ../obj/04_Decorator# 目标文件目录
BINDIR  = ../bin# 可执行文件目录

# ------------------------------------------------------------
# 二、编译器配置
# ------------------------------------------------------------

CC      = gcc
CFLAGS  = -Wall -g

# ------------------------------------------------------------
# 三、目标配置
# ------------------------------------------------------------

EXEC    = $(BINDIR)/decorator# 可执行文件
SRC     = $(SRCDIR)/code.c# 源文件
OBJ     = $(OBJDIR)/code.o# 目标文件

# ------------------------------------------------------------
# 四、默认目标
# ------------------------------------------------------------

all: dir build                        # 创建目录 → 编译链接

dir:
	@mkdir -p $(OBJDIR)
	@mkdir -p $(BINDIR)

build: $(OBJ) $(EXEC)

# ------------------------------------------------------------
# 五、编译和链接规则
# ------------------------------------------------------------

$(EXEC): $(OBJ)
	$(CC) $(CFLAGS) -o $@ $(OBJ)

$(OBJDIR)/%.o: $(SRCDIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# ------------------------------------------------------------
# 六、清理
# ------------------------------------------------------------

clean:
	-rm -rf $(EXEC) $(OBJ)

.PHONY: all dir build clean help

help:
	@echo "04_Decorator - 装饰器模式"
	@echo "用法: make && ./decorator"
