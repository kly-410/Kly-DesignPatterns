# ============================================================
# PART1/01_Singleton/Makefile — 单例模式
#
# 本章节演示：如何确保一个类只能创建一个实例
# 单例模式在嵌入式场景常用于：全局配置、驱动实例、内存池
# ============================================================

# ------------------------------------------------------------
# 一、编译器与编译选项
# ------------------------------------------------------------

# CC = C 编译器
CC = gcc

# CFLAGS = 编译选项
#   -Wall        开启所有警告
#   -Wextra      开启额外警告
#   -g           生成调试信息
#   -D_GNU_SOURCE 启用 GNU 扩展（pthread_once 需要）
CFLAGS = -Wall -Wextra -g -D_GNU_SOURCE

# LDFLAGS = 链接器选项（Linker Flags）
#   -pthread  链接 POSIX 线程库（用于 pthread_once 实现线程安全单例）
LDFLAGS = -pthread

# ------------------------------------------------------------
# 二、目录与文件路径
# ------------------------------------------------------------

# SRC_DIR = 源代码目录（Source Directory）
SRC_DIR = src

# INC_DIR = 头文件目录（Include Directory）
INC_DIR = include

# TARGET = 最终生成的可执行文件名
TARGET = singleton_test

# INCLUDES = 头文件搜索路径
#   -I$(INC_DIR)  在 INC_DIR 目录中搜索 #include 的头文件
#   gcc 默认搜索：/usr/include、/usr/local/include
#   加上 -I 选项后，会先在指定目录搜索
INCLUDES = -I$(INC_DIR)

# ------------------------------------------------------------
# 三、源文件与目标文件
# ------------------------------------------------------------

# SOURCES = 所有需要编译的 .c 源文件列表
# 本例有 2 个源文件：
#   main.c                 — 测试入口
#   singleton_pthread_once.c — pthread_once 方式实现单例
SOURCES = $(SRC_DIR)/main.c $(SRC_DIR)/singleton_pthread_once.c

# OBJECTS = 目标文件列表（.c → .o）
# 替换规则：$(SOURCES:.c=.o) 把每个 .c 路径中的扩展名换成 .o
OBJECTS = $(SOURCES:.c=.o)

# ------------------------------------------------------------
# 四、规则定义
# ------------------------------------------------------------

# .PHONY 声明：这些不是真实文件名，而是操作标签
.PHONY: all clean

# all: 默认目标 = 编译
# 依赖 $(TARGET)，make 会先确保目标文件都编译好了
all: $(TARGET)

# 链接规则：把 .o 文件链接成可执行文件
# $^ = 所有依赖（所有 .o 文件）
# $(LDFLAGS) = 链接器选项（-pthread）
$(TARGET): $(OBJECTS)
	$(CC) $(CFLAGS) -o $@ $^ $(LDFLAGS)

# 编译规则：.c → .o
# $< = 依赖列表中的第一个（正在处理的 .c 文件）
# $(INCLUDES) = 头文件搜索路径
%.o: %.c
	$(CC) $(CFLAGS) $(INCLUDES) -c $< -o $@

# ------------------------------------------------------------
# 五、清理
# ------------------------------------------------------------

# clean: 删除所有 .o 文件和可执行文件
clean:
	rm -f $(TARGET) $(OBJECTS)

# ------------------------------------------------------------
# 六、常用命令
# ------------------------------------------------------------
# make        — 编译
# make clean  — 清理
# make run    — 编译并运行（需手动添加）
