# ============================================================
# PART0_预备知识/Makefile — C语言的面向对象写法
#
# 本章节演示：在 C 语言中如何用结构体 + 函数指针模拟面向对象
# 由于是单文件编译，Makefile 相对简单
# ============================================================

# ------------------------------------------------------------
# 一、变量定义（Makefile 使用 = 或 := 赋值，推荐 := 防止递归展开）
# ------------------------------------------------------------

# CC = C 编译器
# 推荐使用 gcc，嵌入式也可能是 arm-none-eabi-gcc、riscv64-unknown-elf-gcc 等
CC      := gcc

# CFLAGS = 编译选项（Compiler Flags）
#   -Wall        开启所有警告（Warning all）
#   -Wextra      开启额外警告（Warning extra），比 -Wall 更严格
#   -std=c11     指定 C 语言标准版本（C11 是 2011 年发布的 ISO 标准）
#   -g           生成调试信息（用于 gdb 调试，关闭可减少体积：-g0）
CFLAGS  := -Wall -Wextra -std=c11 -g

# TARGET = 最终生成的可执行文件名
TARGET  := test

# SRCS = 源文件列表（Source files）
# 这里只有一个源文件 code.c，多个文件时用空格分隔：
#   SRCS = main.c utils.c config.c
SRCS    := code.c

# OBJ = 目标文件列表（Object files）
# 自动化变量替换：把 SRCS 中的 .c 替换成 .o
# 例如：SRCS = code.c → OBJ = code.o
#       SRCS = a.c b.c → OBJ = a.o b.o
OBJ     := $(SRCS:.c=.o)

# ------------------------------------------------------------
# 二、伪目标声明
# ------------------------------------------------------------
# .PHONY 声明的目标不生成文件，只是标签
# 不声明的话，如果目录下恰好有名为 "all" 的文件，make 会认为它已最新
.PHONY: all run clean rebuild help

# ------------------------------------------------------------
# 三、默认目标（make 不带参数时执行的目标）
# ------------------------------------------------------------

# all: 是默认入口，执行完整编译
# 依赖 $(TARGET)，所以 make 时会先编译所有 .c 文件，再链接
all: $(TARGET)

# ------------------------------------------------------------
# 四、编译规则
# ------------------------------------------------------------

# 链接规则：把所有 .o 文件合并成可执行文件
# $@  = 目标文件名（即 $(TARGET)）
# $^  = 所有依赖文件（即所有 .o 文件）
# $<  = 依赖列表中的第一个文件
$(TARGET): $(OBJ)
	$(CC) $(CFLAGS) $(OBJ) -o $@
	@echo "✅ 编译完成：$(TARGET)"

# 编译规则：把每个 .c 文件编译成 .o 目标文件
# % 是通配符：%.o 匹配所有 .o 文件，%.c 匹配对应的 .c 文件
# 规则格式：目标: 依赖 → 命令
# $(CC) $(CFLAGS) -c $< -o $@
#   -c        只编译不链接（compile only）
#   $<        依赖中的第一个（正在处理的 .c 文件）
#   -o $@     输出为 $@（对应的 .o 文件）
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@
	@echo "  编译: $< → $@"

# ------------------------------------------------------------
# 五、常用目标
# ------------------------------------------------------------

# run: 编译并运行
# 第一行 $(TARGET) 确保已编译，第二行运行
run: $(TARGET)
	@echo "▶ 运行测试..."
	@echo ""
	./$(TARGET)
	@echo ""
	@echo "✅ 测试完成"

# clean: 清理编译产物
# -f  忽略文件不存在的错误（防止多次执行报错）
# $(TARGET) $(OBJ) 要清理的可执行文件和目标文件
clean:
	rm -f $(TARGET) $(OBJ)
	@echo "🧹 清理完成"

# rebuild: 先清理再编译（重新编译）
# 等价于 make clean && make
rebuild: clean all

# help: 显示帮助信息
# @ 前缀表示不打印命令本身，只输出 echo 的内容
help:
	@echo "PART0 — Makefile 使用说明"
	@echo "=============================="
	@echo "make        编译（默认）"
	@echo "make run    编译并运行"
	@echo "make clean  清理编译产物"
	@echo "make rebuild 先清理再编译"
	@echo "make help   显示本帮助"
