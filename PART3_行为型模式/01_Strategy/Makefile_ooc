# Makefile — 策略模式（OOC风格）
#
# 继承 QMonkey/OOC-Design-Pattern 的目录结构：
#   include/  — 头文件（接口和结构体声明）
#   src/      — 源文件（具体实现）
#   lib/include/ — 公共基础框架（base.h）
#
# 编译变量：
#   CC          C编译器
#   CFLAGS      编译选项
#   INCLUDES    头文件搜索路径（-I 指定）
#   SRCS        所有.c源文件
#   OBJS        目标文件列表
#   TARGET      最终可执行文件

CC      := gcc
CFLAGS  := -Wall -Wextra -std=c11 -g
# 头文件搜索路径：
#   include/       — 本章的头文件
#   ../../lib/include  — 公共基础框架（base.h）
INCLUDES := -I include -I ../../lib/include

# 合并编译选项和头文件路径
CFLAGS += $(INCLUDES)

# 所有源文件
SRCS    := src/main.c \
           src/person.c \
           src/train_strategy.c \
           src/airplane_strategy.c

# 目标文件列表
OBJS    := $(SRCS:.c=.o)

# 最终可执行文件
TARGET  := test_ooc

# 默认目标
all: $(TARGET)

# 链接
$(TARGET): $(OBJS)
	$(CC) $(CFLAGS) $(OBJS) -o $(TARGET)
	@echo "✅ OOC风格编译完成：$(TARGET)"

# 编译.c -> .o
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@
	@echo "  编译: $<"

# 运行
run: $(TARGET)
	@echo "▶ 运行 OOC风格示例..."
	@echo ""
	./$(TARGET)
	@echo ""

# 清理
clean:
	rm -f $(TARGET) $(OBJS)
	@echo "🧹 清理完成"

rebuild: clean all

.PHONY: all run clean rebuild
