# ============================================================
# PART3/01_Strategy/Makefile — 策略模式
#
# 本章节演示：定义一系列算法，可相互替换，运行时动态切换
# 策略模式在嵌入式场景常用于：
#   排序算法：快速排序、归并排序、插入排序（根据数据量选择）
#   压缩算法：ZIP、RAR、LZ4（根据场景选择）
#
# 用法：
#   make        — 编译
#   make run    — 编译并运行
#   make clean  — 清理
# ============================================================

# ------------------------------------------------------------
# 一、变量定义
# ------------------------------------------------------------

# CC = C 编译器
# := 赋值防止递归展开（推荐用法）
CC      := gcc

# CFLAGS = 编译选项
#   -Wall      开启所有警告
#   -Wextra    开启额外警告
#   -std=c11   使用 C11 标准
#   -g         生成调试信息
CFLAGS  := -Wall -Wextra -std=c11 -g

# LDFLAGS = 链接器选项（Linker Flags）
#   -lm  链接数学库（libm）
#         bright_exp 函数内部调用 exp()，exp 在 libm 中
LDFLAGS := -lm

# TARGET = 可执行文件名
TARGET  := test

# SRCS = 源文件列表
SRCS    := code.c

# OBJ = 目标文件列表（.c → .o）
OBJ     := $(SRCS:.c=.o)

# ------------------------------------------------------------
# 二、伪目标声明
# ------------------------------------------------------------

.PHONY: all run clean rebuild

# ------------------------------------------------------------
# 三、默认目标
# ------------------------------------------------------------

# all: 编译并链接
all: $(TARGET)

# ------------------------------------------------------------
# 四、编译和链接规则
# ------------------------------------------------------------

# 链接：把所有 .o 文件链接成可执行文件
# $(LDFLAGS) 在最后，因为它是链接器选项
# $@ = 目标（可执行文件），$^ = 所有依赖（.o 文件）
$(TARGET): $(OBJ)
	$(CC) $(CFLAGS) $(OBJ) $(LDFLAGS) -o $(TARGET)
	@echo "✅ 编译完成：$(TARGET)"

# 编译：.c → .o
# $< = 正在处理的 .c 文件，-o $@ = 输出为对应的 .o 文件
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@
	@echo "  编译: $<"

# ------------------------------------------------------------
# 五、常用目标
# ------------------------------------------------------------

# run: 编译并运行
run: $(TARGET)
	@echo "▶ 运行..."
	@echo ""
	./$(TARGET)
	@echo ""
	@echo "✅ 完成"

# clean: 清理编译产物
clean:
	rm -f $(TARGET) $(OBJ)
	@echo "🧹 清理完成"

# rebuild: 先清理再编译
rebuild: clean all
