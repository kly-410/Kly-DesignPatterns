# ============================================================
# PART3/06_Template/Makefile — 模板方法模式
#
# 本章节演示：定义算法骨架，某些步骤延迟到子类实现
# 模板方法在嵌入式场景常用于：
#   测试框架：setup() → run() → teardown()（骨架固定，步骤不同）
#   固件启动：硬件检查 → 内存初始化 → 外设初始化 → 加载应用
#   协议处理：解析Header → 验证 → 处理Payload → 响应（流程固定）
#
# 用法：
#   make       — 编译
#   make test — 编译并运行
#   make clean — 清理
# ============================================================

# ------------------------------------------------------------
# 一、编译器配置
# ------------------------------------------------------------

CC      := gcc
CFLAGS  := -Wall -Wextra -g -O0

# ------------------------------------------------------------
# 二、目标配置
# ------------------------------------------------------------

TARGET  := template_demo
SRCS    := code.c
OBJS    := $(SRCS:.c=.o)

# ------------------------------------------------------------
# 三、伪目标声明
# ------------------------------------------------------------

.PHONY: test clean rebuild

# ------------------------------------------------------------
# 四、编译和链接规则
# ------------------------------------------------------------

$(TARGET): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^
	@echo "✅ 编译成功: $(TARGET)"

%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

# ------------------------------------------------------------
# 五、运行和清理
# ------------------------------------------------------------

test: $(TARGET)
	./$(TARGET)

clean:
	rm -f $(TARGET) $(OBJS)
	@echo "🧹 清理完成"

rebuild: clean $(TARGET)
