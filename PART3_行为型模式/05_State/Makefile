# ============================================================
# PART3/05_State/Makefile — 状态模式
#
# 本章节演示：对象行为随内部状态改变（状态机）
# 状态模式在嵌入式场景常用于：
#   DMA 传输状态：Idle → Setup → Running → Complete → Error
#   驱动状态：Closed → Opened → Working → Suspended → Error
#   TCP 连接状态：Closed → Listen → SynSent → Established → Closing
#   PCIe 链路训练：Detect → Polling → Configuration → L0
#
# 用法：
#   make       — 编译
#   make test — 编译并运行
#   make clean — 清理
# ============================================================

# ------------------------------------------------------------
# 一、编译器配置
# ------------------------------------------------------------

CC      := gcc
CFLAGS  := -Wall -Wextra -g -O0

# ------------------------------------------------------------
# 二、目标配置
# ------------------------------------------------------------

TARGET  := state_demo
SRCS    := code.c
OBJS    := $(SRCS:.c=.o)

# ------------------------------------------------------------
# 三、伪目标声明
# ------------------------------------------------------------

.PHONY: test clean rebuild

# ------------------------------------------------------------
# 四、编译和链接规则
# ------------------------------------------------------------

$(TARGET): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^
	@echo "✅ 编译成功: $(TARGET)"

%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

# ------------------------------------------------------------
# 五、运行和清理
# ------------------------------------------------------------

test: $(TARGET)
	./$(TARGET)

clean:
	rm -f $(TARGET) $(OBJS)

rebuild: clean $(TARGET)
