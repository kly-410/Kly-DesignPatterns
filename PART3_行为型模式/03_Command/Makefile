# ============================================================
# PART3/03_Command/Makefile — 命令模式
#
# 本章节演示：将请求封装为对象，支持撤销/重做、命令队列、延迟执行
# 命令模式在嵌入式场景常用于：
#   固件升级命令队列（可撤销的事务操作）
#   事务性操作（数据库、文件系统）
#   UI 撤销/重做
#
# 用法：
#   make       — 编译
#   make test — 编译并运行
#   make clean — 清理
# ============================================================

# ------------------------------------------------------------
# 一、编译器配置
# ------------------------------------------------------------

CC      := gcc
CFLAGS  := -Wall -Wextra -g -O0

# ------------------------------------------------------------
# 二、目标配置
# ------------------------------------------------------------

TARGET  := command_demo
SRCS    := code.c
OBJS    := $(SRCS:.c=.o)

# ------------------------------------------------------------
# 三、伪目标声明
# ------------------------------------------------------------

.PHONY: test clean rebuild

# ------------------------------------------------------------
# 四、编译和链接规则
# ------------------------------------------------------------

$(TARGET): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^
	@echo "✅ 编译成功: $(TARGET)"

%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

# ------------------------------------------------------------
# 五、运行和清理
# ------------------------------------------------------------

test: $(TARGET)
	./$(TARGET)

clean:
	rm -f $(TARGET) $(OBJS)
	@echo "🧹 清理完成"

rebuild: clean $(TARGET)
