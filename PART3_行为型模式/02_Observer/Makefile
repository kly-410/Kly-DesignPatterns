# ============================================================
# PART3/02_Observer/Makefile — 观察者模式
#
# 本章节演示：一对多依赖关系，状态变化时自动通知所有依赖者
# 观察者模式在嵌入式场景常用于：
#   中断处理：硬件中断 → 所有注册的处理程序收到通知
#   消息推送：发布者有新消息 → 所有订阅者收到
#   MVC 架构：Model 变化 → View 自动更新
#
# 用法：
#   make       — 编译
#   make test — 编译并运行
#   make clean — 清理
# ============================================================

# ------------------------------------------------------------
# 一、编译器配置
# ------------------------------------------------------------

# CC = C 编译器
CC      := gcc

# CFLAGS = 编译选项
#   -Wall      开启所有警告
#   -Wextra    开启额外警告
#   -g         生成调试信息
#   -O0        优化级别为 0（禁用优化，方便调试）
#              不写 -O 默认是 -O0（调试时推荐）
CFLAGS  := -Wall -Wextra -g -O0

# ------------------------------------------------------------
# 二、目标配置
# ------------------------------------------------------------

TARGET  := observer_demo             # 可执行文件名
SRCS    := code.c                    # 源文件列表
OBJS    := $(SRCS:.c=.o)            # 目标文件列表（.c → .o）

# ------------------------------------------------------------
# 三、伪目标声明
# ------------------------------------------------------------

.PHONY: test clean rebuild

# ------------------------------------------------------------
# 四、编译和链接规则
# ------------------------------------------------------------

# 链接：$@ = 目标，$^ = 所有依赖
$(TARGET): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^
	@echo "✅ 编译成功: $(TARGET)"

# 编译：%.o 依赖 %.c（模式规则）
%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

# ------------------------------------------------------------
# 五、运行和清理
# ------------------------------------------------------------

# test: 编译并运行（输出格式化的分隔线）
test: $(TARGET)
	@echo "========================================"
	@echo "  运行 Observer Pattern 演示程序"
	@echo "========================================"
	./$(TARGET)

# clean: 删除编译产物
clean:
	rm -f $(TARGET) $(OBJS)
	@echo "🧹 清理完成"

# rebuild: 先清理再编译
rebuild: clean $(TARGET)
