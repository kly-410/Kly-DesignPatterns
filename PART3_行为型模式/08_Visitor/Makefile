# ============================================================
# PART3/08_Visitor/Makefile — 访问者模式
#
# 本章节演示：数据结构稳定，但操作经常变化
# 访问者模式在嵌入式场景常用于：
#   PCIe 配置空间：寄存器结构固定，但需要读取/验证/日志等不同操作
#   编译器：AST 结构固定，但需要优化/代码生成/格式化等操作
#   文件系统：目录结构固定，但需要统计大小/检查权限/压缩等
#
# 用法：
#   make       — 编译
#   make test — 编译并运行
#   make clean — 清理
# ============================================================

# ------------------------------------------------------------
# 一、编译器配置
# ------------------------------------------------------------

CC      := gcc
CFLAGS  := -Wall -Wextra -g -O0

# ------------------------------------------------------------
# 二、目标配置
# ------------------------------------------------------------

TARGET  := visitor_demo
SRCS    := code.c
OBJS    := $(SRCS:.c=.o)

# ------------------------------------------------------------
# 三、伪目标声明
# ------------------------------------------------------------

.PHONY: test clean rebuild

# ------------------------------------------------------------
# 四、编译和链接规则
# ------------------------------------------------------------

$(TARGET): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^
	@echo "✅ 编译成功: $(TARGET)"

%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

# ------------------------------------------------------------
# 五、运行和清理
# ------------------------------------------------------------

test: $(TARGET)
	./$(TARGET)

clean:
	rm -f $(TARGET) $(OBJS)
	@echo "🧹 清理完成"

rebuild: clean $(TARGET)
