# ============================================================
# PART3/09_Interpreter/Makefile — 解释器模式
#
# 本章节演示：定义语言的语法表示，解释其中的句子
# 解释器模式在嵌入式场景常用于：
#   配置协议解析：AT 命令解析、JSON/XML 解析
#   脚本引擎：嵌入式 Lua 脚本解释
#   表达式计算：配置规则表达式求值
#
# 用法：
#   make       — 编译
#   make test — 编译并运行
#   make clean — 清理
# ============================================================

# ------------------------------------------------------------
# 一、编译器配置
# ------------------------------------------------------------

CC      := gcc
CFLAGS  := -Wall -Wextra -g -O0

# ------------------------------------------------------------
# 二、目标配置
# ------------------------------------------------------------

TARGET  := interpreter_demo
SRCS    := code.c
OBJS    := $(SRCS:.c=.o)

# ------------------------------------------------------------
# 三、伪目标声明
# ------------------------------------------------------------

.PHONY: test clean rebuild

# ------------------------------------------------------------
# 四、编译和链接规则
# ------------------------------------------------------------

$(TARGET): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^
	@echo "✅ 编译成功: $(TARGET)"

%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

# ------------------------------------------------------------
# 五、运行和清理
# ------------------------------------------------------------

test: $(TARGET)
	./$(TARGET)

clean:
	rm -f $(TARGET) $(OBJS)
	@echo "🧹 清理完成"

rebuild: clean $(TARGET)
